# Docling-Graph Showcase Application - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# Ollama Configuration (Local LLM)
# ============================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=granite3.1:8b

# ============================================
# watsonx Orchestrate Configuration
# ============================================
WO_DEVELOPER_EDITION_SOURCE=orchestrate
WO_INSTANCE=xxx
WO_API_KEY=xxx

# ============================================
# Remote API Keys (Optional)
# ============================================
MISTRAL_API_KEY=your_key_here
OPENAI_API_KEY=your_key_here
GEMINI_API_KEY=your_key_here

# ============================================
# Application Settings
# ============================================
GRADIO_SERVER_PORT=7860
GRADIO_SERVER_NAME=0.0.0.0

# ============================================
# Processing Defaults
# ============================================
# Default backend: llm or vlm
DEFAULT_BACKEND=llm

# Default processing mode: one-to-one or many-to-one
DEFAULT_PROCESSING_MODE=many-to-one

# Enable chunking by default: true or false
DEFAULT_USE_CHUNKING=true

# ============================================
# Notes
# ============================================
# - For Ollama: Only OLLAMA_BASE_URL and OLLAMA_MODEL are required
# - For watsonx: Fill in WO_INSTANCE and WO_API_KEY
# - For remote providers: Fill in the respective API keys
# - Leave unused API keys as "your_key_here"